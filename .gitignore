# Local Terraform directories
**/.terraform/

# State files (never commit real state)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files that may contain secrets (keep example file)
*.tfvars
!terraform.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Lock file is optional to commit; many teams commit it for reproducibility.
# Uncomment the next line if you prefer not to commit .terraform.lock.hcl:
# .terraform.lock.hcl
